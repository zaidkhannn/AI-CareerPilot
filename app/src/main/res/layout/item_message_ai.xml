<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp"
    android:gravity="start|top">

    <!-- Avatar Container -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_ai_orb"
        android:padding="6dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_ai_robot"
            android:contentDescription="AI Interviewer"
            android:tint="@color/electric_cyan"
            app:tint="@color/electric_cyan" />

    </FrameLayout>

    <!-- Message Bubble -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_chat_bubble"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Interviewer Name / Label -->
        <TextView
            android:id="@+id/msg_ai_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Interviewer"
            android:textColor="@color/electric_cyan"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp" />

        <!-- Feedback Section (Visually distinct if present) -->
        <TextView
            android:id="@+id/msg_ai_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="3dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Next Question Section -->
        <TextView
            android:id="@+id/msg_ai_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:text="Initializing..." />

    </LinearLayout>

</LinearLayout>
