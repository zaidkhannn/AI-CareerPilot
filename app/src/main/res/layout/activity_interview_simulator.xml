<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- HEADER BAR -->
    <RelativeLayout
        android:id="@+id/simulator_header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/sim_back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text_primary"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/sim_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-black"
            android:text="Voice AI Interviewer"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <!-- End Interview Action -->
        <TextView
            android:id="@+id/sim_end_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackground"
            android:padding="8dp"
            android:text="End Session"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:fontFamily="sans-serif-bold" />

    </RelativeLayout>

    <!-- CONTAINER 1: VOICE CONSOLE SCREEN (Visible by default) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chat_container_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/simulator_header">

        <!-- Top Role Details Card -->
        <TextView
            android:id="@+id/sim_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="Software Engineer (Entry-Level)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/sim_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chat_bubble"
            android:backgroundTint="#1A00D4FF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:text="AI is speaking..."
            android:textColor="@color/electric_cyan"
            android:textSize="12sp"
            android:fontFamily="sans-serif-bold"
            android:textAllCaps="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sim_status_text" />

        <!-- AI Speaking Orb / Avatar Area -->
        <FrameLayout
            android:id="@+id/ai_orb_container"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sim_status_badge">

            <!-- Pulse Rings for AI Speaking animation -->
            <View
                android:id="@+id/sim_ai_pulse_1"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_ai_orb"
                android:backgroundTint="#1A00D4FF"
                android:visibility="invisible" />

            <View
                android:id="@+id/sim_ai_pulse_2"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_ai_orb"
                android:backgroundTint="#0D00D4FF"
                android:layout_margin="10dp"
                android:visibility="invisible" />

            <!-- Core Orb -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ai_orb"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/sim_ai_robot_img"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_ai_robot"
                    android:tint="@color/white"
                    app:tint="@color/white"
                    android:contentDescription="AI Orb" />

            </FrameLayout>

        </FrameLayout>

        <!-- Scrollable Voice Console content area (Question text reference + Transcription feedback) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@id/mic_control_container"
            app:layout_constraintTop_toBottomOf="@id/ai_orb_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Question reference panel -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Question"
                            android:textColor="@color/electric_cyan"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/sim_question_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Interviewer is preparing the initial question..."
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Real-time Transcription panel -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Spoken Answer Transcript"
                            android:textColor="@color/royal_blue"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/sim_transcription_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Your transcription will appear here in real-time as you speak..."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

        <!-- Microphone Control Panel -->
        <FrameLayout
            android:id="@+id/mic_control_container"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Pulse Rings for Recording/Mic input scale (Dynamic RMS waveform) -->
            <View
                android:id="@+id/sim_mic_pulse_1"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_ai_orb"
                android:backgroundTint="#1A3B82F6"
                android:visibility="invisible" />

            <View
                android:id="@+id/sim_mic_pulse_2"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/bg_ai_orb"
                android:backgroundTint="#0D3B82F6"
                android:layout_margin="10dp"
                android:visibility="invisible" />

            <!-- Core Mic Key -->
            <ImageButton
                android:id="@+id/sim_mic_btn"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_mic_button"
                android:src="@drawable/ic_mic"
                android:tint="@color/white"
                app:tint="@color/white"
                android:contentDescription="Microphone"
                android:padding="18dp" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTAINER 2: EVALUATION SCREEN (Hidden by default) -->
    <ScrollView
        android:id="@+id/evaluation_container_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/simulator_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Verdict and Score Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/glass_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overall Performance"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="14dp" />

                    <!-- Circular style Score Display -->
                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_ai_orb"
                        android:backgroundTint="#16233A"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:id="@+id/eval_score_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorAccent"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="out of 100"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- Verdict Badge -->
                    <TextView
                        android:id="@+id/eval_verdict_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chat_bubble"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="6dp"
                        android:text="PENDING"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: qualitative summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/glass_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evaluation Summary"
                        android:textColor="@color/colorAccent"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/eval_summary_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:text="Summary evaluation..." />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: Strengths -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/glass_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Key Strengths"
                        android:textColor="@color/success_green"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/eval_strengths_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:text="• Strength points..." />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: Weaknesses -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/glass_card"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Key Areas for Improvement"
                        android:textColor="@color/error_red"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/eval_weaknesses_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:text="• Improvement areas..." />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: Recommendations -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/glass_card"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended Study Focus"
                        android:textColor="@color/colorAccent"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:textAllCaps="true"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/eval_recommendations_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:text="• Recommendations..." />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Finish Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/back_to_prep_btn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/btn_gradient"
                android:text="Return to Prep Dashboard"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textAllCaps="false" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
