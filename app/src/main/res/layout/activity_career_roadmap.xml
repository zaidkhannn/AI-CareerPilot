<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text_primary"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-black"
            android:text="Career Roadmap"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

    </RelativeLayout>

    <!-- Main Workspace Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <!-- Selector Settings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/glass_card"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Row 1: Target Career Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Career"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="4dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/edit_text_bg"
                    android:layout_marginBottom="10dp"
                    android:paddingHorizontal="12dp">

                    <Spinner
                        android:id="@+id/roadmap_role_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:textColor="@color/text_primary"
                        android:popupBackground="@color/glass_card" />

                </FrameLayout>

                <!-- Row 2: Skill Level & Study Time Spinner Layout -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- Col 1: Skill Level -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Level"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/edit_text_bg"
                            android:paddingHorizontal="12dp">

                            <Spinner
                                android:id="@+id/roadmap_skill_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:textColor="@color/text_primary"
                                android:popupBackground="@color/glass_card" />

                        </FrameLayout>

                    </LinearLayout>

                    <!-- Col 2: Daily Study Hours -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Study Hours / Day"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/edit_text_bg"
                            android:paddingHorizontal="12dp">

                            <Spinner
                                android:id="@+id/roadmap_hours_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:textColor="@color/text_primary"
                                android:popupBackground="@color/glass_card" />

                        </FrameLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Generate Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/roadmap_generate_btn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/btn_gradient"
                    android:text="Generate Roadmap"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Loading Progress -->
        <RelativeLayout
            android:id="@+id/roadmap_loading_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:id="@+id/roadmap_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:indeterminateTint="@color/colorAccent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="8dp"
                android:text="AI Architecting Roadmap..."
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

        </RelativeLayout>

        <!-- Scrollable content area for generated cards -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Dynamic Basic Summary Card (Duration, Phase count, Difficulty) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/roadmap_summary_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center">

                        <!-- Col 1: Total Phases -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/roadmap_phases_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorAccent"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Phases"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="@color/glass_card_stroke" />

                        <!-- Col 2: Completion Time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/roadmap_time_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Duration"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="32dp"
                            android:background="@color/glass_card_stroke" />

                        <!-- Col 3: Difficulty -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/roadmap_difficulty_val"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Difficulty"
                                android:textColor="@color/text_secondary"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- NEW: Career Insights Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/roadmap_insights_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Career Insights"
                            android:textColor="@color/colorAccent"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="12dp" />

                        <!-- Insights columns layout -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="2"
                            android:alignmentMode="alignMargins">

                            <!-- Salary -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="10dp"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Avg Salary Range"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/roadmap_salary_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>

                            <!-- Market Demand -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="10dp"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Market Demand"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/roadmap_demand_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>

                            <!-- Competition -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Competition Level"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/roadmap_competition_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>

                            <!-- Future Growth -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Future Growth"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/roadmap_growth_val"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>

                        </GridLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Container for Phase Cards -->
                <LinearLayout
                    android:id="@+id/roadmap_cards_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- NEW: Final Outcome Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/roadmap_outcome_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Final Career Outcome"
                            android:textColor="@color/colorAccent"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="12dp" />

                        <!-- Job Readiness progress -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estimated Job Readiness"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/roadmap_readiness_pct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="0%"
                                android:textColor="@color/colorAccent"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-bold" />

                            <ProgressBar
                                android:id="@+id/roadmap_readiness_progress"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:progress="0"
                                android:layout_marginTop="20dp"
                                android:progressTint="@color/colorAccent"
                                android:progressBackgroundTint="@color/glass_card_stroke" />

                        </RelativeLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Skills you will obtain:"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/roadmap_outcome_skills"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Skills..."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- NEW: Job Roles Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/roadmap_roles_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/glass_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Target Job Roles"
                            android:textColor="@color/colorAccent"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-bold"
                            android:textAllCaps="true"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/roadmap_job_roles_val"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Frontend Developer, UI Developer"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            android:lineSpacingExtra="3dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
